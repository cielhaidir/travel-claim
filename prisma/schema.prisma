// Travel and Claim Management System - Prisma Schema
// Database: PostgreSQL
// Generated Prisma Client: ../generated/prisma

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum Role {
  ROOT
  EMPLOYEE
  SUPERVISOR
  MANAGER
  DIRECTOR
  FINANCE
  ADMIN
  SALES_EMPLOYEE
  SALES_CHIEF
}

enum TravelType {
  SALES
  OPERATIONAL
  MEETING
  TRAINING
}

enum TravelStatus {
  DRAFT
  SUBMITTED
  APPROVED_L1
  APPROVED_L2
  APPROVED_L3
  APPROVED_L4
  APPROVED_L5
  APPROVED
  REJECTED
  REVISION
  LOCKED
  CLOSED
}

enum ApprovalLevel {
  SALES_LEAD // L1: Sales lead on the project (only for employees on sales travel)
  DEPT_CHIEF // L2: Department chief / head
  DIRECTOR // L3: Director (supervisor of dept chief)
  SENIOR_DIRECTOR // L4: Senior director
  EXECUTIVE // L5: Executive / C-level
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

enum ClaimType {
  ENTERTAINMENT
  NON_ENTERTAINMENT
}

enum ClaimStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REVISION
  PAID
}

enum EntertainmentType {
  MEAL
  GIFT
  EVENT
  HOSPITALITY
  OTHER
}

enum NonEntertainmentCategory {
  TRANSPORT
  PHONE_BILLING
  TRAVEL_EXPENSES
  OVERTIME_MEALS
  BPJS_HEALTH
  EQUIPMENT_STATIONERY
  MOTORCYCLE_SERVICE
  ACCOMMODATION
  OTHER
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  IN_APP
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  READ
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  SUBMIT
  LOCK
  CLOSE
  REOPEN
}

enum COAType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum BailoutStatus {
  DRAFT
  SUBMITTED
  APPROVED_CHIEF
  APPROVED_DIRECTOR
  REJECTED
  DISBURSED
}

enum BailoutCategory {
  TRANSPORT
  HOTEL
  MEAL
  OTHER
}

enum TransportMode {
  FLIGHT
  TRAIN
  BUS
  FERRY
  CAR_RENTAL
  OTHER
}

enum JournalEntryType {
  DEBIT
  CREDIT
}

enum JournalSourceType {
  CLAIM
  BAILOUT
  ADJUSTMENT
  FUNDING
  MANUAL
  SETTLEMENT
}

enum JournalStatus {
  DRAFT
  POSTED
  VOID
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum CrmLeadStage {
  NEW
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum CrmLeadPriority {
  LOW
  MEDIUM
  HIGH
}

enum CrmGender {
  MALE
  FEMALE
  OTHER
}

enum CrmIndustry {
  TECHNOLOGY
  FINANCE
  HEALTHCARE
  EDUCATION
  MANUFACTURING
  RETAIL
  LOGISTICS
  HOSPITALITY
  GOVERNMENT
  OTHER
}

enum CrmEmployeeRange {
  ONE_TO_TEN
  ELEVEN_TO_FIFTY
  FIFTY_ONE_TO_TWO_HUNDRED
  TWO_HUNDRED_ONE_TO_FIVE_HUNDRED
  FIVE_HUNDRED_ONE_TO_ONE_THOUSAND
  OVER_ONE_THOUSAND
}

enum CrmLeadStatus {
  NEW
  CONTACTED
  NURTURE
  QUALIFIED
  CONVERTED
  UNQUALIFIED
  JUNK
}

enum CrmDealStage {
  DISCOVERY
  PROPOSAL
  NEGOTIATION
  VERBAL_WON
  WON
  LOST
  ON_HOLD
}

enum CrmDealStatus {
  QUALIFICATION
  DEMO_MAKING
  PROPOSAL_QUOTATION
  NEGOTIATION
  READY_TO_CLOSE
  WON
  LOST
}

enum CrmLeadSource {
  REFERRAL
  WEBSITE
  EVENT
  OUTBOUND
  PARTNER
}

enum CrmCustomerSegment {
  ENTERPRISE
  SMB
  GOVERNMENT
  EDUCATION
}

enum CrmCustomerStatus {
  ACTIVE
  INACTIVE
  VIP
}

enum CrmActivityType {
  CALL
  MEETING
  EMAIL
  FOLLOW_UP
  CHAT
  STAGE_CHANGE
  NOTE
  TASK
  ATTACHMENT
  SYSTEM
}

enum CrmConversationStatus {
  OPEN
  WAITING_REPLY
  CLOSED
}

enum CrmMessageStatus {
  DRAFT
  SENT
  RECEIVED
  NOTE
}

enum CrmTaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CrmTaskPriority {
  LOW
  MEDIUM
  HIGH
}

// ============================================================================
// AUTHENTICATION MODELS (NextAuth.js)
// ============================================================================

model Tenant {
  id        String    @id @default(cuid()) // -- ID unik tenant ini.
  slug      String    @unique @db.VarChar(100) // -- Slug tenant ini.
  name      String    @db.VarChar(200) // -- Nama tenant ini.
  isRoot    Boolean   @default(false) // -- Menandakan apakah tenant ini merupakan tenant root.
  deletedAt DateTime? // -- Waktu penghapusan lunak tenant ini.
  createdAt DateTime  @default(now()) // -- Waktu pembuatan tenant ini.
  updatedAt DateTime  @updatedAt // -- Waktu terakhir pembaruan tenant ini.

  memberships         TenantMembership[] // -- Daftar keanggotaan tenant yang terkait dengan tenant ini.
  rolePermissions     RolePermission[] // -- Daftar izin peran yang terkait dengan tenant ini.
  userRoles           UserRole[] // -- Daftar peran pengguna yang terkait dengan tenant ini.
  departments         Department[] // -- Daftar departemen yang terkait dengan tenant ini.
  projects            Project[] // -- Daftar proyek yang terkait dengan tenant ini.
  travelRequests      TravelRequest[] // -- Daftar permintaan perjalanan dinas yang terkait dengan tenant ini.
  travelParticipants  TravelParticipant[] // -- Daftar peserta perjalanan yang terkait dengan tenant ini.
  bailouts            Bailout[] // -- Daftar dana talangan yang terkait dengan tenant ini.
  approvals           Approval[] // -- Daftar persetujuan yang terkait dengan tenant ini.
  claims              Claim[] // -- Daftar klaim yang terkait dengan tenant ini.
  attachments         Attachment[] // -- Daftar lampiran yang terkait dengan tenant ini.
  notifications       Notification[] // -- Daftar notifikasi yang terkait dengan tenant ini.
  auditLogs           AuditLog[] // -- Daftar log audit yang terkait dengan tenant ini.
  chartOfAccounts     ChartOfAccount[] // -- Daftar akun COA yang terkait dengan tenant ini.
  balanceAccounts     BalanceAccount[] // -- Daftar akun saldo yang terkait dengan tenant ini.
  journalTransactions JournalTransaction[] // -- Daftar transaksi jurnal yang terkait dengan tenant ini.
  journalEntries      JournalEntry[] // -- Daftar entri jurnal yang terkait dengan tenant ini.
  crmCustomers        CrmCustomer[] // -- Daftar pelanggan CRM yang terkait dengan tenant ini.
  crmContacts         CrmContact[] // -- Daftar kontak CRM yang terkait dengan tenant ini.
  crmLeads            CrmLead[] // -- Daftar prospek CRM yang terkait dengan tenant ini.
  crmDeals            CrmDeal[] // -- Daftar deal CRM yang terkait dengan tenant ini.
  crmTasks            CrmTask[]
  crmNotes            CrmNote[]
  crmRecordAttachments CrmRecordAttachment[]
  crmActivities       CrmActivity[] // -- Daftar aktivitas CRM yang terkait dengan tenant ini.
  crmConversations    CrmConversation[] // -- Daftar percakapan CRM yang terkait dengan tenant ini.
  crmMessages         CrmMessage[] // -- Daftar pesan CRM yang terkait dengan tenant ini.
  customRoles         TenantCustomRole[] // -- Daftar peran kustom tenant yang terkait dengan tenant ini.

  @@index([isRoot])
}

model TenantMembership {
  id              String           @id @default(cuid()) // -- ID unik keanggotaan tenant ini.
  userId          String // -- ID pengguna yang terkait dengan keanggotaan tenant ini.
  tenantId        String // -- ID tenant yang terkait dengan keanggotaan tenant ini.
  role            Role             @default(EMPLOYEE) // -- Peran keanggotaan tenant ini.
  customRoleId    String? // -- ID peran kustom yang terkait dengan keanggotaan tenant ini.
  status          MembershipStatus @default(ACTIVE) // -- Status keanggotaan tenant ini.
  isDefault       Boolean          @default(false) // -- Menandakan apakah keanggotaan tenant ini menjadi pilihan default.
  invitedAt       DateTime? // -- Waktu pengiriman undangan keanggotaan tenant ini.
  activatedAt     DateTime? // -- Waktu aktivasi keanggotaan tenant ini.
  suspendedAt     DateTime? // -- Waktu penangguhan keanggotaan tenant ini.
  suspendedReason String?          @db.Text // -- Alasan penangguhan keanggotaan tenant ini.
  createdAt       DateTime         @default(now()) // -- Waktu pembuatan keanggotaan tenant ini.
  updatedAt       DateTime         @updatedAt // -- Waktu terakhir pembaruan keanggotaan tenant ini.

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade) // -- Relasi ke pengguna untuk keanggotaan tenant ini.
  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade) // -- Relasi ke tenant untuk keanggotaan tenant ini.
  customRole TenantCustomRole? @relation(fields: [customRoleId], references: [id], onDelete: SetNull) // -- Relasi ke peran kustom tenant untuk keanggotaan tenant ini.

  @@unique([userId, tenantId])
  @@index([tenantId, role])
  @@index([customRoleId])
  @@index([tenantId, customRoleId])
  @@index([userId, isDefault])
  @@index([status])
}

// Necessary for Next auth
model Account {
  id                       String  @id @default(cuid()) // -- ID unik akun ini.
  userId                   String // -- ID pengguna yang terkait dengan akun ini.
  type                     String // -- Tipe akun ini.
  provider                 String // -- Penyedia akun ini.
  providerAccountId        String // -- ID akun penyedia yang terkait dengan akun ini.
  refresh_token            String? @db.Text // -- Token refresh akun ini.
  access_token             String? @db.Text // -- Token akses akun ini.
  expires_at               Int? // -- Waktu kedaluwarsa token akun ini.
  token_type               String? // -- Jenis token akun ini.
  scope                    String? // -- Cakupan akses akun ini.
  id_token                 String? @db.Text // -- ID token akun ini.
  session_state            String? // -- Status sesi akun ini.
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade) // -- Relasi ke pengguna untuk akun ini.
  refresh_token_expires_in Int? // -- Durasi kedaluwarsa refresh token akun ini.

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid()) // -- ID unik sesi ini.
  sessionToken String   @unique // -- Token sesi ini.
  userId       String // -- ID pengguna yang terkait dengan sesi ini.
  expires      DateTime // -- Waktu kedaluwarsa sesi ini.
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade) // -- Relasi ke pengguna untuk sesi ini.
}

model User {
  id            String    @id @default(cuid()) // -- ID unik pengguna ini.
  name          String? // -- Nama pengguna ini.
  email         String?   @unique // -- Email pengguna ini.
  emailVerified DateTime? // -- Waktu verifikasi email pengguna ini.
  image         String? // -- Gambar pengguna ini.
  accounts      Account[] // -- Daftar akun yang terkait dengan pengguna ini.
  sessions      Session[] // -- Daftar sesi yang terkait dengan pengguna ini.

  // Extended user fields
  employeeId   String?     @unique @db.VarChar(50) // -- ID pegawai yang terkait dengan pengguna ini.
  role         Role        @default(EMPLOYEE) // -- Peran pengguna ini.
  userRoles    UserRole[] // -- Daftar peran pengguna yang terkait dengan pengguna ini.
  departmentId String? // -- ID departemen yang terkait dengan pengguna ini.
  department   Department? @relation(fields: [departmentId], references: [id]) // -- Relasi ke departemen untuk pengguna ini.

  // Org hierarchy: every user points to their direct supervisor.
  // For a regular employee their supervisor is their dept chief.
  // For a dept chief their supervisor is the director above them.
  supervisorId  String? // -- ID atasan yang terkait dengan pengguna ini.
  supervisor    User?   @relation("Supervision", fields: [supervisorId], references: [id]) // -- Relasi ke pengguna untuk pengguna ini.
  directReports User[]  @relation("Supervision") // -- Daftar pengguna yang terkait dengan pengguna ini.

  // Phone for WhatsApp
  phoneNumber String? @db.VarChar(20) // -- Nomor telepon pengguna ini.

  password String? // -- Kata sandi pengguna ini.

  // Soft delete
  deletedAt DateTime? // -- Waktu penghapusan lunak pengguna ini.

  createdAt DateTime @default(now()) // -- Waktu pembuatan pengguna ini.
  updatedAt DateTime @updatedAt // -- Waktu terakhir pembaruan pengguna ini.

  // Relations
  travelRequests       TravelRequest[]     @relation("TravelRequester") // -- Daftar permintaan perjalanan dinas yang terkait dengan pengguna ini.
  travelParticipations TravelParticipant[] // -- Daftar peserta perjalanan yang terkait dengan pengguna ini.
  claims               Claim[] // -- Daftar klaim yang terkait dengan pengguna ini.
  bailoutsRequested    Bailout[]           @relation("BailoutRequester") // -- Daftar dana talangan yang terkait dengan pengguna ini.
  approvals            Approval[] // -- Daftar persetujuan yang terkait dengan pengguna ini.
  notifications        Notification[] // -- Daftar notifikasi yang terkait dengan pengguna ini.
  auditLogs            AuditLog[] // -- Daftar log audit yang terkait dengan pengguna ini.
  salesProjects        Project[]           @relation("SalesLead") // -- Daftar proyek yang terkait dengan pengguna ini.
  financeBailouts      Bailout[]           @relation("FinanceBailouts") // -- Daftar dana talangan yang terkait dengan pengguna ini.
  financeClaims        Claim[]             @relation("FinanceClaims") // -- Daftar klaim yang terkait dengan pengguna ini.

  // Departments this user leads as chief
  ledDepartments Department[] @relation("DepartmentChief") // -- Daftar departemen yang terkait dengan pengguna ini.

  // Chart of Accounts relations
  coaCreated ChartOfAccount[] @relation("COACreatedBy") // -- Daftar akun COA yang terkait dengan pengguna ini.
  coaUpdated ChartOfAccount[] @relation("COAUpdatedBy") // -- Daftar akun COA yang terkait dengan pengguna ini.

  memberships TenantMembership[] // -- Daftar keanggotaan tenant yang terkait dengan pengguna ini.

  journalEntriesCreated JournalEntry[] @relation("JournalEntryCreatedBy") // -- Daftar entri jurnal yang terkait dengan pengguna ini.
  journalEntriesPosted  JournalEntry[] @relation("JournalEntryPostedBy") // -- Daftar entri jurnal yang terkait dengan pengguna ini.

  @@index([employeeId])
  @@index([email])
  @@index([departmentId])
  @@index([supervisorId])
  @@index([role])
}

model UserRole {
  tenantId  String? // -- ID tenant yang terkait dengan peran pengguna ini.
  userId    String // -- ID pengguna yang terkait dengan peran pengguna ini.
  role      Role // -- Peran pengguna ini.
  createdAt DateTime @default(now()) // -- Waktu pembuatan peran pengguna ini.
  createdBy String? // -- ID pengguna pembuat peran pengguna ini.

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade) // -- Relasi ke pengguna untuk peran pengguna ini.
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull) // -- Relasi ke tenant untuk peran pengguna ini.

  @@id([userId, role])
  @@index([role])
  @@index([tenantId])
}

model RolePermission {
  id          String   @id @default(cuid()) // -- ID unik izin peran ini.
  tenantId    String // -- ID tenant yang terkait dengan izin peran ini.
  role        Role // -- Peran yang diatur dalam izin peran ini.
  displayName String?  @db.VarChar(100) // -- Nama tampilan izin peran ini.
  isArchived  Boolean  @default(false) // -- Menandakan apakah izin peran ini diarsipkan.
  permissions Json // -- Daftar izin untuk izin peran ini.
  createdAt   DateTime @default(now()) // -- Waktu pembuatan izin peran ini.
  updatedAt   DateTime @updatedAt // -- Waktu terakhir pembaruan izin peran ini.

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade) // -- Relasi ke tenant untuk izin peran ini.

  @@unique([tenantId, role])
  @@index([role])
  @@index([tenantId])
}

model TenantCustomRole {
  id          String   @id @default(cuid()) // -- ID unik peran kustom tenant ini.
  tenantId    String // -- ID tenant yang terkait dengan peran kustom tenant ini.
  baseRole    Role? // -- Peran dasar untuk peran kustom tenant ini.
  isSystem    Boolean  @default(false) // -- Menandakan apakah peran kustom tenant ini dikelola oleh sistem.
  slug        String   @db.VarChar(120) // -- Slug peran kustom tenant ini.
  displayName String   @db.VarChar(100) // -- Nama tampilan peran kustom tenant ini.
  isArchived  Boolean  @default(false) // -- Menandakan apakah peran kustom tenant ini diarsipkan.
  permissions Json // -- Daftar izin peran kustom tenant ini.
  defaultPermissions Json // -- Daftar izin bawaan peran kustom tenant ini.
  createdAt   DateTime @default(now()) // -- Waktu pembuatan peran kustom tenant ini.
  updatedAt   DateTime @updatedAt // -- Waktu terakhir pembaruan peran kustom tenant ini.

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade) // -- Relasi ke tenant untuk peran kustom tenant ini.
  memberships  TenantMembership[] // -- Daftar keanggotaan tenant yang terkait dengan peran kustom tenant ini.

  @@unique([tenantId, slug])
  @@index([tenantId, isArchived])
  @@index([baseRole])
  @@index([tenantId, isSystem])
  @@index([tenantId])
}

model VerificationToken {
  identifier String // -- Pengenal token verifikasi ini.
  token      String   @unique // -- Token verifikasi ini.
  expires    DateTime // -- Waktu kedaluwarsa token verifikasi ini.

  @@unique([identifier, token])
}

// ============================================================================
// ORGANIZATIONAL STRUCTURE
// ============================================================================

model Department {
  id          String  @id @default(cuid()) // -- ID unik departemen ini.
  tenantId    String? // -- ID tenant yang terkait dengan departemen ini.
  name        String  @db.VarChar(100) // -- Nama departemen ini.
  code        String  @db.VarChar(20) // -- Kode departemen ini.
  description String? @db.Text // -- Deskripsi departemen ini.

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull) // -- Relasi ke tenant untuk departemen ini.

  // Department hierarchy
  parentId String? // -- ID induk yang terkait dengan departemen ini.
  parent   Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id]) // -- Relasi ke departemen untuk departemen ini.
  children Department[] @relation("DepartmentHierarchy") // -- Daftar departemen yang terkait dengan departemen ini.

  // The single chief / head of this department.
  // This user's own supervisorId points to the director above them.
  chiefId String? // -- ID kepala departemen yang terkait dengan departemen ini.
  chief   User?   @relation("DepartmentChief", fields: [chiefId], references: [id]) // -- Relasi ke pengguna untuk departemen ini.

  deletedAt DateTime? // -- Waktu penghapusan lunak departemen ini.
  createdAt DateTime  @default(now()) // -- Waktu pembuatan departemen ini.
  updatedAt DateTime  @updatedAt // -- Waktu terakhir pembaruan departemen ini.

  users User[] // -- Daftar pengguna yang terkait dengan departemen ini.

  @@unique([tenantId, code])
  @@index([code])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([parentId])
  @@index([chiefId])
}

// ============================================================================
// CHART OF ACCOUNTS (COA)
// ============================================================================

model ChartOfAccount {
  id          String  @id @default(cuid()) // -- ID unik akun COA ini.
  tenantId    String? // -- ID tenant yang terkait dengan akun COA ini.
  code        String  @db.VarChar(20) // -- Kode akun COA ini.
  name        String  @db.VarChar(100) // -- Nama akun COA ini.
  accountType COAType // -- Akun tipe akun COA ini.
  category    String  @db.VarChar(50) // -- Kategori akun COA ini.
  subcategory String? @db.VarChar(50) // -- Subkategori akun COA ini.

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull) // -- Relasi ke tenant untuk akun COA ini.

  // Self-referential hierarchy
  parentId String? // -- ID induk yang terkait dengan akun COA ini.
  parent   ChartOfAccount?  @relation("COAParent", fields: [parentId], references: [id]) // -- Relasi ke akun COA untuk akun COA ini.
  children ChartOfAccount[] @relation("COAParent") // -- Daftar akun COA yang terkait dengan akun COA ini.

  isActive    Boolean @default(true) // -- Menandakan apakah akun COA ini aktif.
  description String? @db.Text // -- Deskripsi akun COA ini.

  // Audit fields
  createdById String // -- ID pengguna pembuat yang terkait dengan akun COA ini.
  createdBy   User   @relation("COACreatedBy", fields: [createdById], references: [id]) // -- Relasi ke pengguna untuk akun COA ini.
  updatedById String // -- ID pengguna terakhir yang memperbarui yang terkait dengan akun COA ini.
  updatedBy   User   @relation("COAUpdatedBy", fields: [updatedById], references: [id]) // -- Relasi ke pengguna untuk akun COA ini.

  createdAt DateTime @default(now()) // -- Waktu pembuatan akun COA ini.
  updatedAt DateTime @updatedAt // -- Waktu terakhir pembaruan akun COA ini.

  // Relations
  claims                    Claim[] // -- Daftar klaim yang terkait dengan akun COA ini.
  auditLogs                 AuditLog[]           @relation("COAAuditLogs") // -- Daftar log audit yang terkait dengan akun COA ini.
  journalTransactions       JournalTransaction[] // -- Daftar transaksi jurnal yang terkait dengan akun COA ini.
  journalEntryLines         JournalEntryLine[] // -- Daftar baris entri jurnal yang terkait dengan akun COA ini.
  defaultForBalanceAccounts BalanceAccount[]     @relation("BalanceAccountDefaultCOA") // -- Daftar akun saldo yang terkait dengan akun COA ini.

  @@unique([tenantId, code])
  @@index([code])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([accountType])
  @@index([parentId])
  @@index([isActive])
}

// ============================================================================
// PROJECT (for SALES travel type)
// ============================================================================

model Project {
  id          String    @id @default(cuid()) // -- ID unik proyek ini.
  tenantId    String? // -- ID tenant yang terkait dengan proyek ini.
  code        String    @db.VarChar(30) // -- Kode proyek ini.
  name        String    @db.VarChar(200) // -- Nama proyek ini.
  description String?   @db.Text // -- Deskripsi proyek ini.
  clientName  String?   @db.VarChar(200) // -- Nama klien proyek ini.
  isActive    Boolean   @default(true) // -- Menandakan apakah proyek ini aktif.
  deletedAt   DateTime? // -- Waktu penghapusan lunak proyek ini.
  createdAt   DateTime  @default(now()) // -- Waktu pembuatan proyek ini.
  updatedAt   DateTime  @updatedAt // -- Waktu terakhir pembaruan proyek ini.
  salesId     String?   @db.VarChar(50) // -- ID pimpinan sales yang terkait dengan proyek ini.
  salesLead   User?     @relation("SalesLead", fields: [salesId], references: [employeeId]) // -- Relasi ke pengguna untuk proyek ini.
  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull) // -- Relasi ke tenant untuk proyek ini.

  travelRequests TravelRequest[] // -- Daftar permintaan perjalanan dinas yang terkait dengan proyek ini.

  @@unique([tenantId, code])
  @@index([code])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([isActive])
}

// ============================================================================
// CRM
// ============================================================================

model CrmCustomer {
  id            String             @id @default(cuid()) // -- ID unik organisasi CRM ini.
  tenantId      String?
  name          String?            @db.VarChar(150)
  company       String             @db.VarChar(200)
  email         String?            @db.VarChar(200)
  phone         String?            @db.VarChar(30)
  segment       CrmCustomerSegment @default(SMB)
  city          String?            @db.VarChar(100)
