// Travel and Claim Management System - Prisma Schema
// Database: PostgreSQL
// Generated Prisma Client: ../generated/prisma

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum Role {
  ROOT
  EMPLOYEE
  SUPERVISOR
  MANAGER
  DIRECTOR
  FINANCE
  ADMIN
  SALES_EMPLOYEE
  SALES_CHIEF
}

enum TravelType {
  SALES
  OPERATIONAL
  MEETING
  TRAINING
}

enum TravelStatus {
  DRAFT
  SUBMITTED
  APPROVED_L1
  APPROVED_L2
  APPROVED_L3
  APPROVED_L4
  APPROVED_L5
  APPROVED
  REJECTED
  REVISION
  LOCKED
  CLOSED
}

enum ApprovalLevel {
  SALES_LEAD // L1: Sales lead on the project (only for employees on sales travel)
  DEPT_CHIEF // L2: Department chief / head
  DIRECTOR // L3: Director (supervisor of dept chief)
  SENIOR_DIRECTOR // L4: Senior director
  EXECUTIVE // L5: Executive / C-level
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

enum ClaimType {
  ENTERTAINMENT
  NON_ENTERTAINMENT
}

enum ClaimStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REVISION
  PAID
}

enum EntertainmentType {
  MEAL
  GIFT
  EVENT
  HOSPITALITY
  OTHER
}

enum NonEntertainmentCategory {
  TRANSPORT
  PHONE_BILLING
  TRAVEL_EXPENSES
  OVERTIME_MEALS
  BPJS_HEALTH
  EQUIPMENT_STATIONERY
  MOTORCYCLE_SERVICE
  ACCOMMODATION
  OTHER
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  IN_APP
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  READ
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  SUBMIT
  LOCK
  CLOSE
  REOPEN
}

enum COAType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum BailoutStatus {
  DRAFT
  SUBMITTED
  APPROVED_CHIEF
  APPROVED_DIRECTOR
  REJECTED
  DISBURSED
}

enum BailoutCategory {
  TRANSPORT
  HOTEL
  MEAL
  OTHER
}

enum TransportMode {
  FLIGHT
  TRAIN
  BUS
  FERRY
  CAR_RENTAL
  OTHER
}

enum JournalEntryType {
  DEBIT
  CREDIT
}

enum JournalSourceType {
  CLAIM
  BAILOUT
  ADJUSTMENT
  FUNDING
  MANUAL
  SETTLEMENT
}

enum JournalStatus {
  DRAFT
  POSTED
  VOID
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum CrmLeadStage {
  NEW
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum CrmLeadPriority {
  LOW
  MEDIUM
  HIGH
}

enum CrmLeadSource {
  REFERRAL
  WEBSITE
  EVENT
  OUTBOUND
  PARTNER
}

enum CrmCustomerSegment {
  ENTERPRISE
  SMB
  GOVERNMENT
  EDUCATION
}

enum CrmCustomerStatus {
  ACTIVE
  INACTIVE
  VIP
}

enum CrmActivityType {
  CALL
  MEETING
  EMAIL
  FOLLOW_UP
}

// ============================================================================
// AUTHENTICATION MODELS (NextAuth.js)
// ============================================================================

model Tenant {
  id        String    @id @default(cuid())
  slug      String    @unique @db.VarChar(100)
  name      String    @db.VarChar(200)
  isRoot    Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  memberships         TenantMembership[]
  userRoles           UserRole[]
  departments         Department[]
  projects            Project[]
  travelRequests      TravelRequest[]
  travelParticipants  TravelParticipant[]
  bailouts            Bailout[]
  approvals           Approval[]
  claims              Claim[]
  attachments         Attachment[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  chartOfAccounts     ChartOfAccount[]
  balanceAccounts     BalanceAccount[]
  journalTransactions JournalTransaction[]
  journalEntries      JournalEntry[]
  crmCustomers        CrmCustomer[]
  crmLeads            CrmLead[]
  crmActivities       CrmActivity[]

  @@index([isRoot])
}

model TenantMembership {
  id              String           @id @default(cuid())
  userId          String
  tenantId        String
  role            Role             @default(EMPLOYEE)
  status          MembershipStatus @default(ACTIVE)
  isDefault       Boolean          @default(false)
  invitedAt       DateTime?
  activatedAt     DateTime?
  suspendedAt     DateTime?
  suspendedReason String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId, role])
  @@index([userId, isDefault])
  @@index([status])
}

// Necessary for Next auth
model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? // @db.Text
  access_token             String? // @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? // @db.Text
  session_state            String?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  refresh_token_expires_in Int?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // Extended user fields
  employeeId   String?     @unique @db.VarChar(50)
  role         Role        @default(EMPLOYEE)
  userRoles    UserRole[]
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  // Org hierarchy: every user points to their direct supervisor.
  // For a regular employee their supervisor is their dept chief.
  // For a dept chief their supervisor is the director above them.
  supervisorId  String?
  supervisor    User?   @relation("Supervision", fields: [supervisorId], references: [id])
  directReports User[]  @relation("Supervision")

  // Phone for WhatsApp
  phoneNumber String? @db.VarChar(20)

  password String?

  // Soft delete
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  travelRequests       TravelRequest[]     @relation("TravelRequester")
  travelParticipations TravelParticipant[]
  claims               Claim[]
  bailoutsRequested    Bailout[]           @relation("BailoutRequester")
  approvals            Approval[]
  notifications        Notification[]
  auditLogs            AuditLog[]
  salesProjects        Project[]           @relation("SalesLead")
  financeBailouts      Bailout[]           @relation("FinanceBailouts")
  financeClaims        Claim[]             @relation("FinanceClaims")

  // Departments this user leads as chief
  ledDepartments Department[] @relation("DepartmentChief")

  // Chart of Accounts relations
  coaCreated ChartOfAccount[] @relation("COACreatedBy")
  coaUpdated ChartOfAccount[] @relation("COAUpdatedBy")

  memberships TenantMembership[]

  journalEntriesCreated JournalEntry[] @relation("JournalEntryCreatedBy")
  journalEntriesPosted  JournalEntry[] @relation("JournalEntryPostedBy")

  @@index([employeeId])
  @@index([email])
  @@index([departmentId])
  @@index([supervisorId])
  @@index([role])
}

model UserRole {
  tenantId  String?
  userId    String
  role      Role
  createdAt DateTime @default(now())
  createdBy String?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@id([userId, role])
  @@index([role])
  @@index([tenantId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// ORGANIZATIONAL STRUCTURE
// ============================================================================

model Department {
  id          String  @id @default(cuid())
  tenantId    String?
  name        String  @db.VarChar(100)
  code        String  @db.VarChar(20)
  description String? @db.Text

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  // Department hierarchy
  parentId String?
  parent   Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children Department[] @relation("DepartmentHierarchy")

  // The single chief / head of this department.
  // This user's own supervisorId points to the director above them.
  chiefId String?
  chief   User?   @relation("DepartmentChief", fields: [chiefId], references: [id])

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users User[]

  @@unique([tenantId, code])
  @@index([code])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([parentId])
  @@index([chiefId])
}

// ============================================================================
// CHART OF ACCOUNTS (COA)
// ============================================================================

model ChartOfAccount {
  id          String  @id @default(cuid())
  tenantId    String?
  code        String  @db.VarChar(20)
  name        String  @db.VarChar(100)
  accountType COAType
  category    String  @db.VarChar(50)
  subcategory String? @db.VarChar(50)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  // Self-referential hierarchy
  parentId String?
  parent   ChartOfAccount?  @relation("COAParent", fields: [parentId], references: [id])
  children ChartOfAccount[] @relation("COAParent")

  isActive    Boolean @default(true)
  description String? @db.Text

  // Audit fields
  createdById String
  createdBy   User   @relation("COACreatedBy", fields: [createdById], references: [id])
  updatedById String
  updatedBy   User   @relation("COAUpdatedBy", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  claims                    Claim[]
  auditLogs                 AuditLog[]           @relation("COAAuditLogs")
  journalTransactions       JournalTransaction[]
  journalEntryLines         JournalEntryLine[]
  defaultForBalanceAccounts BalanceAccount[]     @relation("BalanceAccountDefaultCOA")

  @@unique([tenantId, code])
  @@index([code])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([accountType])
  @@index([parentId])
  @@index([isActive])
}

// ============================================================================
// PROJECT (for SALES travel type)
// ============================================================================

model Project {
  id          String    @id @default(cuid())
  tenantId    String?
  code        String    @db.VarChar(30)
  name        String    @db.VarChar(200)
  description String?   @db.Text
  clientName  String?   @db.VarChar(200)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  salesId     String?   @db.VarChar(50) // e.g. employeeId of the sales lead
  salesLead   User?     @relation("SalesLead", fields: [salesId], references: [employeeId])
  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  travelRequests TravelRequest[]

  @@unique([tenantId, code])
  @@index([code])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([isActive])
}

// ============================================================================
// CRM
// ============================================================================

model CrmCustomer {
  id            String             @id @default(cuid())
  tenantId      String?
  name          String             @db.VarChar(150)
  company       String             @db.VarChar(200)
  email         String             @db.VarChar(200)
  phone         String?            @db.VarChar(30)
  segment       CrmCustomerSegment
  city          String?            @db.VarChar(100)
  ownerName     String             @db.VarChar(150)
  status        CrmCustomerStatus  @default(ACTIVE)
  totalValue    Decimal            @default(0) @db.Decimal(15, 2)
  notes         String?            @db.Text
  lastContactAt DateTime?
  deletedAt     DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  tenant     Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  leads      CrmLead[]
  activities CrmActivity[]

  @@index([tenantId])
  @@index([tenantId, company])
  @@index([tenantId, status])
  @@index([tenantId, ownerName])
  @@index([deletedAt])
}

model CrmLead {
  id                String          @id @default(cuid())
  tenantId          String?
  customerId        String?
  name              String          @db.VarChar(150)
  company           String          @db.VarChar(200)
  email             String          @db.VarChar(200)
  phone             String?         @db.VarChar(30)
  stage             CrmLeadStage    @default(NEW)
  value             Decimal         @default(0) @db.Decimal(15, 2)
  probability       Int             @default(0)
  source            CrmLeadSource   @default(REFERRAL)
  priority          CrmLeadPriority @default(MEDIUM)
  ownerName         String          @db.VarChar(150)
  expectedCloseDate DateTime?
  lastActivityAt    DateTime?
  notes             String?         @db.Text
  deletedAt         DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  tenant     Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  customer   CrmCustomer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  activities CrmActivity[]

  @@index([tenantId])
  @@index([tenantId, stage])
  @@index([tenantId, ownerName])
  @@index([customerId])
  @@index([deletedAt])
}

model CrmActivity {
  id          String          @id @default(cuid())
  tenantId    String?
  customerId  String?
  leadId      String?
  title       String          @db.VarChar(200)
  description String?         @db.Text
  type        CrmActivityType @default(FOLLOW_UP)
  ownerName   String          @db.VarChar(150)
  scheduledAt DateTime
  completedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant   Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  customer CrmCustomer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lead     CrmLead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, scheduledAt])
  @@index([customerId])
  @@index([leadId])
  @@index([deletedAt])
}

// ============================================================================
// TRAVEL REQUEST SYSTEM
// ============================================================================

model TravelRequest {
  id            String  @id @default(cuid())
  tenantId      String?
  requestNumber String  @db.VarChar(50)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  // Requester (must be SALES_EMPLOYEE or SALES_CHIEF)
  requesterId String
  requester   User   @relation("TravelRequester", fields: [requesterId], references: [id])

  // Travel details
  purpose     String     @db.Text
  destination String     @db.VarChar(255)
  travelType  TravelType
  startDate   DateTime
  endDate     DateTime

  // SALES type — link to Project
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  // Status
  status TravelStatus @default(DRAFT)

  // Financial (reimbursement tracking only, no estimatedBudget)
  totalReimbursed Decimal? @db.Decimal(15, 2)

  // Lifecycle timestamps
  submittedAt DateTime?
  lockedAt    DateTime?
  closedAt    DateTime?
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  participants TravelParticipant[]
  approvals    Approval[]
  claims       Claim[]
  bailouts     Bailout[]

  @@unique([tenantId, requestNumber])
  @@index([requesterId, status])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([status, createdAt])
  @@index([requestNumber])
  @@index([travelType])
  @@index([startDate, endDate])
  @@index([projectId])
}

model TravelParticipant {
  id              String        @id @default(cuid())
  tenantId        String?
  travelRequestId String
  travelRequest   TravelRequest @relation(fields: [travelRequestId], references: [id], onDelete: Cascade)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  role  String? @db.VarChar(100) // e.g., "Presenter", "Observer"
  notes String? @db.Text

  createdAt DateTime @default(now())

  @@unique([travelRequestId, userId])
  @@index([tenantId])
  @@index([userId])
}

// ============================================================================
// BAILOUT (Dana Talangan)
// ============================================================================

model Bailout {
  id            String  @id @default(cuid())
  tenantId      String?
  bailoutNumber String  @db.VarChar(50)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  travelRequestId String
  travelRequest   TravelRequest @relation(fields: [travelRequestId], references: [id])

  requesterId String
  requester   User   @relation("BailoutRequester", fields: [requesterId], references: [id])

  // Category of spend
  category BailoutCategory @default(OTHER)

  // General
  description String  @db.Text
  amount      Decimal @db.Decimal(15, 2)

  // Transport-specific fields
  transportMode TransportMode?
  carrier       String?        @db.VarChar(100)
  departureFrom String?        @db.VarChar(100)
  arrivalTo     String?        @db.VarChar(100)
  departureAt   DateTime?
  arrivalAt     DateTime?
  flightNumber  String?        @db.VarChar(20)
  seatClass     String?        @db.VarChar(50)
  bookingRef    String?        @db.VarChar(100)

  // Hotel-specific fields
  hotelName    String?   @db.VarChar(255)
  hotelAddress String?   @db.Text
  checkIn      DateTime?
  checkOut     DateTime?
  roomType     String?   @db.VarChar(100)

  // Meal-specific fields
  mealDate     DateTime?
  mealLocation String?   @db.VarChar(255)

  status BailoutStatus @default(DRAFT)

  // Rejection / disbursement lifecycle
  rejectedAt      DateTime?
  rejectionReason String?   @db.Text
  disbursedAt     DateTime?
  disbursementRef String?   @db.VarChar(100)

  // Timestamps
  submittedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Approval chain (generic, same as TravelRequest & Claim)
  approvals Approval[]

  storageUrl String? @db.Text // For any receipt images or documents
  financeId  String? // FK to User (finance officer who processed this bailout)
  finance    User?   @relation("FinanceBailouts", fields: [financeId], references: [id])

  // Reverse relation for journal transactions
  journalTransactions JournalTransaction[]
  journalEntries      JournalEntry[]

  @@unique([tenantId, bailoutNumber])
  @@index([travelRequestId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([requesterId, status])
  @@index([status, createdAt])
  @@index([bailoutNumber])
  @@index([financeId])
}

// ============================================================================
// APPROVAL SYSTEM
// ============================================================================
// One Approval row = one step in the chain for a TravelRequest, Bailout, or Claim.
// The sequence field (1, 2, 3 …) defines the order within a single document.
// The routing logic (who to notify next) lives in the application layer and uses:
//   - User.supervisorId     — the direct supervisor chain
//   - Department.chiefId    — the dept chief for non-sales routes
//   - Project.salesLead     — the sales lead for employee + sales travel
//
// Routing rules (application layer, not enforced by DB):
//
// TravelRequest / Bailout / Claim
// ─────────────────────────────────────────────────────
// Requester role = SALES_EMPLOYEE or SALES_CHIEF
//   → starts at DEPT_CHIEF (sales dept head)
//   → then DIRECTOR (chief.supervisorId)
//   → then SENIOR_DIRECTOR / EXECUTIVE if configured
//
// Requester role = EMPLOYEE (non-sales person)
//   travelType = SALES (linked to a Project)
//     → L1: Project.salesLead  (SALES_LEAD)
//     → L2: salesLead.supervisor (DEPT_CHIEF of sales dept)
//     → L3+: continue up the chain
//   travelType ≠ SALES
//     → L1: requester.department.chief  (DEPT_CHIEF)
//     → L2+: continue up the chain

model Approval {
  id       String  @id @default(cuid())
  tenantId String?

  // Business approval number (e.g. APR-2026-00001)
  approvalNumber String @db.VarChar(50)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  // ── Entity links (exactly one must be set) ──────────────────────────────
  travelRequestId String?
  travelRequest   TravelRequest? @relation(fields: [travelRequestId], references: [id], onDelete: Cascade)

  bailoutId String?
  bailout   Bailout? @relation(fields: [bailoutId], references: [id], onDelete: Cascade)

  claimId String?
  claim   Claim?  @relation(fields: [claimId], references: [id], onDelete: Cascade)

  // ── Approval details ────────────────────────────────────────────────────
  // sequence: 1 = first approver, 2 = second, etc.  Allows dynamic chains.
  sequence Int            @default(1)
  level    ApprovalLevel
  status   ApprovalStatus @default(PENDING)

  approverId String
  approver   User   @relation(fields: [approverId], references: [id])

  comments        String? @db.Text
  rejectionReason String? @db.Text

  // Timestamps
  approvedAt DateTime?
  rejectedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([tenantId, approvalNumber])
  @@index([approvalNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([travelRequestId, sequence])
  @@index([bailoutId, sequence])
  @@index([claimId, sequence])
  @@index([approverId, status])
  @@index([status, createdAt])
}

// ============================================================================
// CLAIMS SYSTEM
// ============================================================================

model Claim {
  id          String  @id @default(cuid())
  tenantId    String?
  claimNumber String  @db.VarChar(50)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  travelRequestId String
  travelRequest   TravelRequest @relation(fields: [travelRequestId], references: [id])

  submitterId String
  submitter   User   @relation(fields: [submitterId], references: [id])

  // Claim type
  claimType ClaimType
  status    ClaimStatus @default(DRAFT)

  // Entertainment-specific fields
  entertainmentType     EntertainmentType?
  entertainmentDate     DateTime?
  entertainmentLocation String?            @db.VarChar(255)
  entertainmentAddress  String?            @db.Text
  guestName             String?            @db.VarChar(255)
  guestCompany          String?            @db.VarChar(255)
  guestPosition         String?            @db.VarChar(100)
  isGovernmentOfficial  Boolean?           @default(false)

  // Non-entertainment-specific fields
  expenseCategory    NonEntertainmentCategory?
  expenseDate        DateTime?
  expenseDestination String?                   @db.VarChar(255)
  customerName       String?                   @db.VarChar(255)

  // Common fields
  amount      Decimal @db.Decimal(15, 2)
  description String  @db.Text
  notes       String? @db.Text

  // Chart of Accounts
  coaId          String?
  chartOfAccount ChartOfAccount? @relation(fields: [coaId], references: [id])

  // Payment
  isPaid           Boolean   @default(false)
  paidAt           DateTime?
  paidBy           String?   @db.VarChar(100)
  paymentReference String?   @db.VarChar(100)

  // Metadata
  submittedVia String? @db.VarChar(50) // "web" or "whatsapp"

  // Finance officer who processed/paid this claim
  financeId String?
  finance   User?   @relation("FinanceClaims", fields: [financeId], references: [id])

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  attachments         Attachment[]
  approvals           Approval[]
  journalTransactions JournalTransaction[]
  journalEntries      JournalEntry[]

  @@unique([tenantId, claimNumber])
  @@index([travelRequestId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([submitterId, status])
  @@index([status, createdAt])
  @@index([claimNumber])
  @@index([claimType])
  @@index([coaId])
  @@index([financeId])
}

model Attachment {
  id       String  @id @default(cuid())
  tenantId String?
  claimId  String
  claim    Claim   @relation(fields: [claimId], references: [id], onDelete: Cascade)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  filename        String @db.VarChar(255)
  originalName    String @db.VarChar(255)
  mimeType        String @db.VarChar(100)
  fileSize        Int // bytes
  storageUrl      String @db.Text
  storageProvider String @db.VarChar(50) // "local", "r2", etc.

  // OCR/AI extracted data
  ocrExtractedData Json?
  ocrConfidence    Decimal? @db.Decimal(5, 2) // 0-100

  deletedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([tenantId])
  @@index([claimId])
}

// ============================================================================
// NOTIFICATION SYSTEM
// ============================================================================

model Notification {
  id       String  @id @default(cuid())
  tenantId String?
  userId   String
  user     User    @relation(fields: [userId], references: [id])

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  // Notification content
  title   String              @db.VarChar(255)
  message String              @db.Text
  channel NotificationChannel
  status  NotificationStatus  @default(PENDING)

  // Links
  entityType String? @db.VarChar(50) // "TravelRequest", "Claim", "Bailout"
  entityId   String?
  actionUrl  String? @db.Text

  // Delivery
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?
  failedAt     DateTime?
  errorMessage String?   @db.Text

  // Metadata
  priority   String  @default("NORMAL") @db.VarChar(20) // "LOW", "NORMAL", "HIGH"
  templateId String? @db.VarChar(100)

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId, status])
  @@index([status, createdAt])
  @@index([channel])
}

// ============================================================================
// AUDIT & COMPLIANCE
// ============================================================================

model AuditLog {
  id       String  @id @default(cuid())
  tenantId String?
  userId   String
  user     User    @relation(fields: [userId], references: [id])

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  // Action details
  action     AuditAction
  entityType String      @db.VarChar(50)
  entityId   String

  // Chart of Accounts relation (optional)
  chartOfAccountId String?
  chartOfAccount   ChartOfAccount? @relation("COAAuditLogs", fields: [chartOfAccountId], references: [id])

  // Changes
  changes  Json? // Before/after snapshots
  metadata Json? // Additional context

  // Request info
  ipAddress String? @db.VarChar(45)
  userAgent String? @db.Text

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@index([chartOfAccountId])
}

// ============================================================================
// ACCOUNTING — BALANCE ACCOUNTS & JOURNAL TRANSACTIONS
// ============================================================================

model BalanceAccount {
  id       String  @id @default(cuid())
  tenantId String?
  code     String  @db.VarChar(30)
  name     String  @db.VarChar(150)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  // Current running balance (positive = debit-normal, or as defined by usage)
  balance Decimal @default(0) @db.Decimal(19, 4)

  defaultChartOfAccountId String?
  defaultChartOfAccount   ChartOfAccount? @relation("BalanceAccountDefaultCOA", fields: [defaultChartOfAccountId], references: [id])

  isActive    Boolean @default(true)
  description String? @db.Text

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Reverse relation
  journalTransactions JournalTransaction[]
  journalEntryLines   JournalEntryLine[]

  @@unique([tenantId, code])
  @@index([code])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([isActive])
  @@index([defaultChartOfAccountId])
}

model JournalTransaction {
  id                String  @id @default(cuid())
  tenantId          String?
  transactionNumber String  @db.VarChar(50) // e.g. JRN-2026-00001

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  // Date of the accounting entry (may differ from createdAt)
  transactionDate DateTime @db.Date

  description String  @db.Text
  amount      Decimal @db.Decimal(15, 2)

  // DEBIT increases the account balance; CREDIT decreases it (or vice-versa
  // depending on account type — the application layer enforces the rule).
  entryType JournalEntryType

  // ── Source document links (at most one set) ──────────────────────────────
  bailoutId String?
  bailout   Bailout? @relation(fields: [bailoutId], references: [id])

  claimId String?
  claim   Claim?  @relation(fields: [claimId], references: [id])

  // ── Accounting links (both required) ─────────────────────────────────────
  chartOfAccountId String
  chartOfAccount   ChartOfAccount @relation(fields: [chartOfAccountId], references: [id])

  balanceAccountId String
  balanceAccount   BalanceAccount @relation(fields: [balanceAccountId], references: [id])

  // Optional reference / notes
  referenceNumber String? @db.VarChar(100)
  notes           String? @db.Text

  // Soft-delete
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, transactionNumber])
  @@index([transactionNumber])
  @@index([tenantId])
  @@index([tenantId, transactionDate])
  @@index([transactionDate])
  @@index([chartOfAccountId])
  @@index([balanceAccountId])
  @@index([bailoutId])
  @@index([claimId])
  @@index([entryType, transactionDate])
}

model JournalEntry {
  id            String  @id @default(cuid())
  tenantId      String?
  journalNumber String  @db.VarChar(50)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  transactionDate DateTime           @db.Date
  description     String             @db.Text
  sourceType      JournalSourceType?
  sourceId        String?
  status          JournalStatus      @default(DRAFT)

  bailoutId String?
  bailout   Bailout? @relation(fields: [bailoutId], references: [id])

  claimId String?
  claim   Claim?  @relation(fields: [claimId], references: [id])

  referenceNumber String? @db.VarChar(100)
  notes           String? @db.Text

  createdById String
  createdBy   User   @relation("JournalEntryCreatedBy", fields: [createdById], references: [id])

  postedById String?
  postedBy   User?     @relation("JournalEntryPostedBy", fields: [postedById], references: [id])
  postedAt   DateTime?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  lines JournalEntryLine[]

  @@unique([tenantId, journalNumber])
  @@index([journalNumber])
  @@index([tenantId])
  @@index([tenantId, transactionDate])
  @@index([transactionDate])
  @@index([sourceType, sourceId])
  @@index([status, transactionDate])
  @@index([bailoutId])
  @@index([claimId])
  @@index([createdById])
  @@index([postedById])
}

model JournalEntryLine {
  id String @id @default(cuid())

  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  chartOfAccountId String
  chartOfAccount   ChartOfAccount @relation(fields: [chartOfAccountId], references: [id])

  balanceAccountId String?
  balanceAccount   BalanceAccount? @relation(fields: [balanceAccountId], references: [id])

  description  String? @db.Text
  debitAmount  Decimal @default(0) @db.Decimal(15, 2)
  creditAmount Decimal @default(0) @db.Decimal(15, 2)
  lineNumber   Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([journalEntryId])
  @@index([chartOfAccountId])
  @@index([balanceAccountId])
  @@index([lineNumber])
}
