model SalesOrder {
  id               String           @id @default(cuid())
  salesOrderNumber String           @unique @db.VarChar(50)
  quotationId      String?
  customerId       String
  salesOwnerId     String?
  salesOwnerName   String?          @db.VarChar(150)
  orderDate        DateTime         @default(now())
  plannedShipDate  DateTime?
  status           SalesOrderStatus @default(DRAFT)
  fulfillmentMode  BusinessFlowType @default(GOODS)
  requiresDelivery Boolean          @default(true)
  subtotalAmount   Decimal          @default(0) @db.Decimal(15, 2)
  taxAmount        Decimal          @default(0) @db.Decimal(15, 2)
  totalAmount      Decimal          @default(0) @db.Decimal(15, 2)
  notes            String?          @db.Text
  deliveredAt      DateTime?
  closedAt         DateTime?
  canceledAt       DateTime?
  deletedAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  quotation      SalesQuotation?  @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  customer       CrmCustomer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  lines          SalesOrderLine[]
  deliveryOrders DeliveryOrder[]
  salesInvoices  SalesInvoice[]

  @@index([salesOrderNumber])
  @@index([quotationId])
  @@index([customerId])
  @@index([status])
  @@index([fulfillmentMode])
  @@index([requiresDelivery])
  @@index([orderDate])
  @@index([plannedShipDate])
  @@index([deletedAt])
}

model SalesOrderLine {
  id                String   @id @default(cuid())
  salesOrderId      String
  salesQuotationLineId String?
  inventoryItemId   String?
  warehouseId       String?
  lineNumber        Int      @default(1)
  description       String?  @db.Text
  qtyOrdered        Decimal  @default(0) @db.Decimal(15, 2)
  qtyDelivered      Decimal  @default(0) @db.Decimal(15, 2)
  qtyInvoiced       Decimal  @default(0) @db.Decimal(15, 2)
  unitPrice         Decimal  @default(0) @db.Decimal(15, 2)
  lineTotal         Decimal  @default(0) @db.Decimal(15, 2)
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  salesOrder      SalesOrder        @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  salesQuotationLine SalesQuotationLine? @relation(fields: [salesQuotationLineId], references: [id], onDelete: SetNull)
  inventoryItem   InventoryItem?    @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  warehouse       Warehouse?        @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  deliveryOrderLines DeliveryOrderLine[]
  salesInvoiceLines  SalesInvoiceLine[]

  @@index([salesOrderId])
  @@index([salesQuotationLineId])
  @@index([inventoryItemId])
  @@index([warehouseId])
}

model DeliveryOrder {
  id                  String              @id @default(cuid())
  deliveryOrderNumber String              @unique @db.VarChar(50)
  salesOrderId        String
  customerId          String
  warehouseId         String?
  shipDate            DateTime            @default(now())
  deliveredAt         DateTime?
  status              DeliveryOrderStatus @default(DRAFT)
  carrierName         String?             @db.VarChar(150)
  trackingNumber      String?             @db.VarChar(100)
  destinationAddress  String?             @db.Text
  notes               String?             @db.Text
  deletedAt           DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  salesOrder    SalesOrder          @relation(fields: [salesOrderId], references: [id], onDelete: Restrict)
  customer      CrmCustomer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  warehouse     Warehouse?          @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  lines         DeliveryOrderLine[]
  salesInvoices SalesInvoice[]

  @@index([deliveryOrderNumber])
  @@index([salesOrderId])
  @@index([customerId])
  @@index([warehouseId])
  @@index([status])
  @@index([shipDate])
  @@index([deletedAt])
}

model DeliveryOrderLine {
  id                String   @id @default(cuid())
  deliveryOrderId   String
  salesOrderLineId  String?
  inventoryItemId   String?
  warehouseId       String?
  lineNumber        Int      @default(1)
  qtyOrdered        Decimal  @default(0) @db.Decimal(15, 2)
  qtyShipped        Decimal  @default(0) @db.Decimal(15, 2)
  qtyDelivered      Decimal  @default(0) @db.Decimal(15, 2)
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  deliveryOrder DeliveryOrder   @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
  salesOrderLine SalesOrderLine? @relation(fields: [salesOrderLineId], references: [id], onDelete: SetNull)
  inventoryItem InventoryItem?  @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  warehouse     Warehouse?      @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  salesInvoiceLines SalesInvoiceLine[]

  @@index([deliveryOrderId])
  @@index([salesOrderLineId])
  @@index([inventoryItemId])
  @@index([warehouseId])
}

model SalesInvoice {
  id                 String             @id @default(cuid())
  salesInvoiceNumber String             @unique @db.VarChar(50)
  customerId         String
  salesOrderId       String?
  deliveryOrderId    String?
  issueDate          DateTime           @default(now())
  dueDate            DateTime?
  status             SalesInvoiceStatus @default(DRAFT)
  subtotalAmount     Decimal            @default(0) @db.Decimal(15, 2)
  taxAmount          Decimal            @default(0) @db.Decimal(15, 2)
  totalAmount        Decimal            @default(0) @db.Decimal(15, 2)
  paidAmount         Decimal            @default(0) @db.Decimal(15, 2)
  notes              String?            @db.Text
  sentAt             DateTime?
  paidAt             DateTime?
  deletedAt          DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  customer      CrmCustomer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  salesOrder    SalesOrder?    @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
  deliveryOrder DeliveryOrder? @relation(fields: [deliveryOrderId], references: [id], onDelete: SetNull)
  lines         SalesInvoiceLine[]

  @@index([salesInvoiceNumber])
  @@index([customerId])
  @@index([salesOrderId])
  @@index([deliveryOrderId])
  @@index([status])
  @@index([issueDate])
  @@index([dueDate])
  @@index([deletedAt])
}

model SalesInvoiceLine {
  id               String   @id @default(cuid())
  salesInvoiceId   String
  salesOrderLineId String?
  deliveryOrderLineId String?
  inventoryItemId  String?
  lineNumber       Int      @default(1)
  description      String?  @db.Text
  qtyInvoiced      Decimal  @default(0) @db.Decimal(15, 2)
  unitPrice        Decimal  @default(0) @db.Decimal(15, 2)
  lineTotal        Decimal  @default(0) @db.Decimal(15, 2)
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  salesInvoice      SalesInvoice      @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
  salesOrderLine    SalesOrderLine?   @relation(fields: [salesOrderLineId], references: [id], onDelete: SetNull)
  deliveryOrderLine DeliveryOrderLine? @relation(fields: [deliveryOrderLineId], references: [id], onDelete: SetNull)
  inventoryItem     InventoryItem?    @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)

  @@index([salesInvoiceId])
  @@index([salesOrderLineId])
  @@index([deliveryOrderLineId])
  @@index([inventoryItemId])
}

model InventoryItem {
  id                   String               @id @default(cuid())
  sku                  String               @unique @db.VarChar(50)
  name                 String               @db.VarChar(200)
  description          String?              @db.Text
  unitOfMeasure        String               @db.VarChar(30)
  category             String?              @db.VarChar(100)
  brand                String?               @db.VarChar(100)
  model                String?               @db.VarChar(150)
  manufacturerPartNumber String?             @db.VarChar(100)
  barcode              String?               @db.VarChar(100)
  technicalSpecs       String?               @db.Text
  trackingMode         InventoryTrackingMode @default(QUANTITY)
  usageType            InventoryUsageType   @default(BOTH)
  itemType             InventoryItemType    @default(HARDWARE)
  isStockTracked       Boolean              @default(true)
  minStock             Decimal              @default(0) @db.Decimal(15, 2)
  reorderPoint         Decimal              @default(0) @db.Decimal(15, 2)
  standardCost         Decimal?             @db.Decimal(15, 2)
  inventoryCoaId       String?
  temporaryAssetCoaId  String?
  cogsCoaId            String?
  isActive             Boolean              @default(true)
  deletedAt            DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  inventoryCoa      ChartOfAccount?             @relation("InventoryItemStockCOA", fields: [inventoryCoaId], references: [id])
  temporaryAssetCoa ChartOfAccount?             @relation("InventoryItemTempAssetCOA", fields: [temporaryAssetCoaId], references: [id])
  cogsCoa           ChartOfAccount?             @relation("InventoryItemCogsCOA", fields: [cogsCoaId], references: [id])
  crmProducts       CrmProduct[]
  leadLines         CrmLeadLine[]
  fulfillmentLines  CrmFulfillmentRequestLine[]
  purchaseRequestLines PurchaseRequestLine[]
  purchaseOrderLines   PurchaseOrderLine[]
  goodsReceiptLines    GoodsReceiptLine[]
  vendorInvoiceLines   VendorInvoiceLine[]
  salesQuotationLines  SalesQuotationLine[]
  salesOrderLines      SalesOrderLine[]
  deliveryOrderLines   DeliveryOrderLine[]
  salesInvoiceLines    SalesInvoiceLine[]
  balances          InventoryBalance[]
  ledgerEntries     InventoryLedgerEntry[]
  reservations      InventoryReservation[]
  units             InventoryItemUnit[]
  receiptBatches    InventoryReceiptBatch[]

  @@index([isActive])
  @@index([inventoryCoaId])
  @@index([temporaryAssetCoaId])
  @@index([cogsCoaId])
  @@index([deletedAt])
}

model Warehouse {
  id          String    @id @default(cuid())
  code        String    @unique @db.VarChar(30)
  name        String    @db.VarChar(150)
  description String?   @db.Text
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  balances            InventoryBalance[]
  ledgerEntries       InventoryLedgerEntry[]
  reservations        InventoryReservation[]
  leadLinePreferences CrmLeadLine[]
  fulfillmentLines    CrmFulfillmentRequestLine[]
  purchaseRequestLines PurchaseRequestLine[]
  purchaseOrderLines   PurchaseOrderLine[]
  goodsReceipts        GoodsReceipt[]
  goodsReceiptLines    GoodsReceiptLine[]
  salesQuotationLines  SalesQuotationLine[]
  salesOrderLines      SalesOrderLine[]
  deliveryOrders       DeliveryOrder[]
  deliveryOrderLines   DeliveryOrderLine[]
  receiptBatches      InventoryReceiptBatch[]
  units               InventoryItemUnit[]

  @@index([isActive])
  @@index([deletedAt])
}

model InventoryItemUnit {
  id                String                 @id @default(cuid())
  inventoryItemId   String
  warehouseId       String?
  receiptBatchId    String?
  bucketType        InventoryBucketType    @default(SALE_STOCK)
  serialNumber      String?                @db.VarChar(150)
  assetTag          String?                @db.VarChar(150)
  batchNumber       String?                @db.VarChar(100)
  status            InventoryUnitStatus    @default(IN_STOCK)
  condition         InventoryUnitCondition @default(NEW)
  receivedDate      DateTime?
  purchaseDate      DateTime?
  warrantyExpiry    DateTime?
  assignedToUserId  String?
  assignedAt        DateTime?
  notes             String?                @db.Text
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  inventoryItem    InventoryItem          @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  warehouse        Warehouse?             @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  receiptBatch     InventoryReceiptBatch? @relation(fields: [receiptBatchId], references: [id], onDelete: SetNull)
  assignedToUser   User?                  @relation("InventoryUnitAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  reservationUnits InventoryReservationUnit[]

  @@unique([serialNumber])
  @@unique([assetTag])
  @@index([inventoryItemId])
  @@index([warehouseId])
  @@index([receiptBatchId])
  @@index([status])
  @@index([condition])
  @@index([bucketType])
  @@index([assignedToUserId])
}

model InventoryReceiptBatch {
  id              String              @id @default(cuid())
  inventoryItemId String
  warehouseId     String
  bucketType      InventoryBucketType @default(SALE_STOCK)
  vendorName      String?             @db.VarChar(150)
  vendorReference String?             @db.VarChar(100)
  batchNumber     String?             @db.VarChar(100)
  unitCost        Decimal?            @db.Decimal(15, 2)
  receivedQty     Decimal             @default(0) @db.Decimal(15, 2)
  remainingQty    Decimal             @default(0) @db.Decimal(15, 2)
  receivedDate    DateTime            @default(now())
  referenceType   String?             @db.VarChar(50)
  referenceId     String?             @db.VarChar(100)
  notes           String?             @db.Text
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  inventoryItem InventoryItem       @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  warehouse     Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  units         InventoryItemUnit[]
  goodsReceiptLines GoodsReceiptLine[]

  @@index([inventoryItemId])
  @@index([warehouseId])
  @@index([bucketType])
  @@index([batchNumber])
  @@index([vendorName])
  @@index([receivedDate])
}

model InventoryReservationUnit {
  id                      String                    @id @default(cuid())
  reservationId           String
  inventoryItemUnitId     String
  fulfillmentRequestLineId String?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt

  reservation           InventoryReservation       @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  inventoryItemUnit     InventoryItemUnit          @relation(fields: [inventoryItemUnitId], references: [id], onDelete: Cascade)
  fulfillmentRequestLine CrmFulfillmentRequestLine? @relation(fields: [fulfillmentRequestLineId], references: [id], onDelete: SetNull)

  @@unique([reservationId, inventoryItemUnitId])
  @@index([inventoryItemUnitId])
  @@index([fulfillmentRequestLineId])
}

model InventoryBalance {
  id          String              @id @default(cuid())
  itemId      String
  warehouseId String
  bucketType  InventoryBucketType @default(SALE_STOCK)
  qtyOnHand   Decimal             @default(0) @db.Decimal(15, 2)
  qtyReserved Decimal             @default(0) @db.Decimal(15, 2)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  warehouse Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([itemId, warehouseId, bucketType])
  @@index([warehouseId])
}

model InventoryLedgerEntry {
  id               String                @id @default(cuid())
  itemId           String
  warehouseId      String
  bucketType       InventoryBucketType   @default(SALE_STOCK)
  movementType     InventoryMovementType
  referenceType    String?               @db.VarChar(50)
  referenceId      String?               @db.VarChar(100)
  chartOfAccountId String?
  quantityBefore   Decimal               @default(0) @db.Decimal(15, 2)
  quantityChange   Decimal               @default(0) @db.Decimal(15, 2)
  quantityAfter    Decimal               @default(0) @db.Decimal(15, 2)
  unitCost         Decimal?              @db.Decimal(15, 2)
  totalCost        Decimal?              @db.Decimal(15, 2)
  notes            String?               @db.Text
  movementDate     DateTime              @default(now())
  createdById      String?
  createdAt        DateTime              @default(now())

  item           InventoryItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  warehouse      Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  chartOfAccount ChartOfAccount? @relation("InventoryLedgerChartOfAccount", fields: [chartOfAccountId], references: [id])
  createdBy      User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([itemId, warehouseId, movementDate])
  @@index([bucketType])
  @@index([referenceType, referenceId])
  @@index([chartOfAccountId])
  @@index([createdById])
}

model InventoryReservation {
  id           String                     @id @default(cuid())
  itemId       String
  warehouseId  String?
  leadLineId   String?
  sourceType   String                     @db.VarChar(50)
  sourceId     String                     @db.VarChar(100)
  qtyReserved  Decimal                    @default(0) @db.Decimal(15, 2)
  qtyFulfilled Decimal                    @default(0) @db.Decimal(15, 2)
  qtyReleased  Decimal                    @default(0) @db.Decimal(15, 2)
  status       InventoryReservationStatus @default(ACTIVE)
  expiresAt    DateTime?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  item             InventoryItem             @relation(fields: [itemId], references: [id], onDelete: Cascade)
  warehouse        Warehouse?                @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  leadLine         CrmLeadLine?              @relation(fields: [leadLineId], references: [id], onDelete: SetNull)
  reservationUnits InventoryReservationUnit[]

  @@index([itemId])
  @@index([warehouseId])
  @@index([leadLineId])
  @@index([sourceType, sourceId])
  @@index([status])
}

// ============================================================================
// TRAVEL REQUEST SYSTEM
// ============================================================================

model TravelRequest {
  id            String  @id @default(cuid()) // -- ID unik permintaan perjalanan dinas ini.
  requestNumber String  @db.VarChar(50) // -- Nomor pengajuan permintaan perjalanan dinas ini.


  // Requester (must be SALES_EMPLOYEE or SALES_CHIEF)
  requesterId String // -- ID pengaju yang terkait dengan permintaan perjalanan dinas ini.
  requester   User   @relation("TravelRequester", fields: [requesterId], references: [id]) // -- Relasi ke pengguna untuk permintaan perjalanan dinas ini.

  // Travel details
  purpose     String     @db.Text // -- Keperluan permintaan perjalanan dinas ini.
  destination String     @db.VarChar(255) // -- Destinasi permintaan perjalanan dinas ini.
  travelType  TravelType // -- Jenis perjalanan permintaan perjalanan dinas ini.
  startDate   DateTime // -- Tanggal mulai permintaan perjalanan dinas ini.
  endDate     DateTime // -- Tanggal selesai permintaan perjalanan dinas ini.

  // SALES type — link to Project
  projectId String? // -- ID proyek yang terkait dengan permintaan perjalanan dinas ini.
  project   Project? @relation(fields: [projectId], references: [id]) // -- Relasi ke proyek untuk permintaan perjalanan dinas ini.

  // Status
  status TravelStatus @default(DRAFT) // -- Status permintaan perjalanan dinas ini.

  // Financial (reimbursement tracking only, no estimatedBudget)
  totalReimbursed Decimal? @db.Decimal(15, 2) // -- Total penggantian permintaan perjalanan dinas ini.

  // Lifecycle timestamps
  submittedAt DateTime? // -- Waktu pengajuan permintaan perjalanan dinas ini.
  lockedAt    DateTime? // -- Waktu penguncian permintaan perjalanan dinas ini.
  closedAt    DateTime? // -- Waktu penutupan permintaan perjalanan dinas ini.
  deletedAt   DateTime? // -- Waktu penghapusan lunak permintaan perjalanan dinas ini.

  createdAt DateTime @default(now()) // -- Waktu pembuatan permintaan perjalanan dinas ini.
  updatedAt DateTime @updatedAt // -- Waktu terakhir pembaruan permintaan perjalanan dinas ini.

  // Relations
  participants TravelParticipant[] // -- Daftar peserta perjalanan yang terkait dengan permintaan perjalanan dinas ini.
  approvals    Approval[] // -- Daftar persetujuan yang terkait dengan permintaan perjalanan dinas ini.
  claims       Claim[] // -- Daftar klaim yang terkait dengan permintaan perjalanan dinas ini.
  bailouts     Bailout[] // -- Daftar dana talangan yang terkait dengan permintaan perjalanan dinas ini.

  @@unique([requestNumber])
  @@index([requesterId, status])
  @@index([status, createdAt])
  @@index([requestNumber])
  @@index([travelType])
  @@index([startDate, endDate])
  @@index([projectId])
}

model TravelParticipant {
  id              String        @id @default(cuid()) // -- ID unik peserta perjalanan ini.
  travelRequestId String // -- ID permintaan perjalanan dinas yang terkait dengan peserta perjalanan ini.
  travelRequest   TravelRequest @relation(fields: [travelRequestId], references: [id], onDelete: Cascade) // -- Relasi ke permintaan perjalanan dinas untuk peserta perjalanan ini.


  userId String // -- ID pengguna yang terkait dengan peserta perjalanan ini.
  user   User   @relation(fields: [userId], references: [id]) // -- Relasi ke pengguna untuk peserta perjalanan ini.

  role  String? @db.VarChar(100) // -- Peran peserta perjalanan ini.
  notes String? @db.Text // -- Catatan peserta perjalanan ini.

  createdAt DateTime @default(now()) // -- Waktu pembuatan peserta perjalanan ini.

  @@unique([travelRequestId, userId])
  @@index([userId])
}

// ============================================================================
// BAILOUT (Dana Talangan)
// ============================================================================

model Bailout {
  id            String  @id @default(cuid()) // -- ID unik dana talangan ini.
  bailoutNumber String  @db.VarChar(50) // -- Nomor dana talangan ini.


  travelRequestId String // -- ID permintaan perjalanan dinas yang terkait dengan dana talangan ini.
  travelRequest   TravelRequest @relation(fields: [travelRequestId], references: [id]) // -- Relasi ke permintaan perjalanan dinas untuk dana talangan ini.

  requesterId String // -- ID pengaju yang terkait dengan dana talangan ini.
  requester   User   @relation("BailoutRequester", fields: [requesterId], references: [id]) // -- Relasi ke pengguna untuk dana talangan ini.

  // Category of spend
  category BailoutCategory @default(OTHER) // -- Kategori dana talangan ini.

  // General
  description String  @db.Text // -- Deskripsi dana talangan ini.
  amount      Decimal @db.Decimal(15, 2) // -- Nominal dana talangan ini.

  // Transport-specific fields
  transportMode TransportMode? // -- Moda transportasi dana talangan ini.
  carrier       String?        @db.VarChar(100) // -- Maskapai dana talangan ini.
  departureFrom String?        @db.VarChar(100) // -- Lokasi keberangkatan dana talangan ini.
  arrivalTo     String?        @db.VarChar(100) // -- Lokasi kedatangan dana talangan ini.
  departureAt   DateTime? // -- Waktu keberangkatan dana talangan ini.
  arrivalAt     DateTime? // -- Waktu kedatangan dana talangan ini.
  flightNumber  String?        @db.VarChar(20) // -- Nomor penerbangan dana talangan ini.
  seatClass     String?        @db.VarChar(50) // -- Kelas kursi dana talangan ini.
  bookingRef    String?        @db.VarChar(100) // -- Referensi pemesanan dana talangan ini.

  // Hotel-specific fields
  hotelName    String?   @db.VarChar(255) // -- Nama hotel dana talangan ini.
  hotelAddress String?   @db.Text // -- Alamat hotel dana talangan ini.
  checkIn      DateTime? // -- Waktu check-in dana talangan ini.
  checkOut     DateTime? // -- Waktu check-out dana talangan ini.
  roomType     String?   @db.VarChar(100) // -- Tipe kamar dana talangan ini.

  // Meal-specific fields
  mealDate     DateTime? // -- Tanggal makan dana talangan ini.
  mealLocation String?   @db.VarChar(255) // -- Lokasi makan dana talangan ini.

  status BailoutStatus @default(DRAFT) // -- Status dana talangan ini.

  // Rejection / disbursement lifecycle
  rejectedAt      DateTime? // -- Waktu penolakan dana talangan ini.
  rejectionReason String?   @db.Text // -- Alasan penolakan dana talangan ini.
  disbursedAt     DateTime? // -- Waktu pencairan dana talangan ini.
  disbursementRef String?   @db.VarChar(100) // -- Referensi pencairan dana talangan ini.

  // Timestamps
  submittedAt DateTime? // -- Waktu pengajuan dana talangan ini.
  deletedAt   DateTime? // -- Waktu penghapusan lunak dana talangan ini.
  createdAt   DateTime  @default(now()) // -- Waktu pembuatan dana talangan ini.
  updatedAt   DateTime  @updatedAt // -- Waktu terakhir pembaruan dana talangan ini.

  // Approval chain (generic, same as TravelRequest & Claim)
  approvals Approval[] // -- Daftar persetujuan yang terkait dengan dana talangan ini.

  storageUrl String? @db.Text // -- URL penyimpanan dana talangan ini.
  financeId  String? // -- ID petugas keuangan yang terkait dengan dana talangan ini.
  finance    User?   @relation("FinanceBailouts", fields: [financeId], references: [id]) // -- Relasi ke pengguna untuk dana talangan ini.

  // Reverse relation for journal transactions
  journalTransactions JournalTransaction[] // -- Daftar transaksi jurnal yang terkait dengan dana talangan ini.
  journalEntries      JournalEntry[] // -- Daftar entri jurnal yang terkait dengan dana talangan ini.

  @@unique([bailoutNumber])
  @@index([travelRequestId])
  @@index([requesterId, status])
  @@index([status, createdAt])
  @@index([bailoutNumber])
  @@index([financeId])
}

// ============================================================================
// APPROVAL SYSTEM
// ============================================================================
// One Approval row = one step in the chain for a TravelRequest, Bailout, or Claim.
// The sequence field (1, 2, 3 …) defines the order within a single document.
// The routing logic (who to notify next) lives in the application layer and uses:
//   - User.supervisorId     — the direct supervisor chain
//   - Department.chiefId    — the dept chief for non-sales routes
//   - Project.salesLead     — the sales lead for employee + sales travel
//
// Routing rules (application layer, not enforced by DB):
//
// TravelRequest / Bailout / Claim
// ─────────────────────────────────────────────────────
// Requester role = SALES_EMPLOYEE or SALES_CHIEF
//   → starts at DEPT_CHIEF (sales dept head)
//   → then DIRECTOR (chief.supervisorId)
//   → then SENIOR_DIRECTOR / EXECUTIVE if configured
//
// Requester role = EMPLOYEE (non-sales person)
//   travelType = SALES (linked to a Project)
//     → L1: Project.salesLead  (SALES_LEAD)
//     → L2: salesLead.supervisor (DEPT_CHIEF of sales dept)
//     → L3+: continue up the chain
//   travelType ≠ SALES
//     → L1: requester.department.chief  (DEPT_CHIEF)
//     → L2+: continue up the chain

model Approval {
  id       String  @id @default(cuid()) // -- ID unik persetujuan ini.

  // Business approval number (e.g. APR-2026-00001)
  approvalNumber String @db.VarChar(50) // -- Nomor persetujuan ini.


  // ── Entity links (exactly one must be set) ──────────────────────────────
  travelRequestId String? // -- ID permintaan perjalanan dinas yang terkait dengan persetujuan ini.
  travelRequest   TravelRequest? @relation(fields: [travelRequestId], references: [id], onDelete: Cascade) // -- Relasi ke permintaan perjalanan dinas untuk persetujuan ini.

  bailoutId String? // -- ID dana talangan yang terkait dengan persetujuan ini.
  bailout   Bailout? @relation(fields: [bailoutId], references: [id], onDelete: Cascade) // -- Relasi ke dana talangan untuk persetujuan ini.

  claimId String? // -- ID klaim yang terkait dengan persetujuan ini.
  claim   Claim?  @relation(fields: [claimId], references: [id], onDelete: Cascade) // -- Relasi ke klaim untuk persetujuan ini.

  // ── Approval details ────────────────────────────────────────────────────
  // sequence: 1 = first approver, 2 = second, etc.  Allows dynamic chains.
  sequence Int            @default(1) // -- Urutan persetujuan ini.
  level    ApprovalLevel // -- Level persetujuan ini.
  status   ApprovalStatus @default(PENDING) // -- Status persetujuan ini.

  approverId String // -- ID penyetuju yang terkait dengan persetujuan ini.
  approver   User   @relation(fields: [approverId], references: [id]) // -- Relasi ke pengguna untuk persetujuan ini.

  comments        String? @db.Text // -- Komentar persetujuan ini.
  rejectionReason String? @db.Text // -- Alasan penolakan persetujuan ini.

  // Timestamps
  approvedAt DateTime? // -- Waktu persetujuan ini.
  rejectedAt DateTime? // -- Waktu penolakan persetujuan ini.
  createdAt  DateTime  @default(now()) // -- Waktu pembuatan persetujuan ini.
  updatedAt  DateTime  @updatedAt // -- Waktu terakhir pembaruan persetujuan ini.

  @@unique([approvalNumber])
  @@index([approvalNumber])
  @@index([travelRequestId, sequence])
  @@index([bailoutId, sequence])
  @@index([claimId, sequence])
  @@index([approverId, status])
  @@index([status, createdAt])
}

// ============================================================================
// CLAIMS SYSTEM
// ============================================================================

model Claim {
  id          String  @id @default(cuid()) // -- ID unik klaim ini.
  claimNumber String  @db.VarChar(50) // -- Nomor klaim ini.


  travelRequestId String // -- ID permintaan perjalanan dinas yang terkait dengan klaim ini.
  travelRequest   TravelRequest @relation(fields: [travelRequestId], references: [id]) // -- Relasi ke permintaan perjalanan dinas untuk klaim ini.

  submitterId String // -- ID pengirim yang terkait dengan klaim ini.
  submitter   User   @relation(fields: [submitterId], references: [id]) // -- Relasi ke pengguna untuk klaim ini.

  // Claim type
  claimType ClaimType // -- Jenis klaim ini.
  status    ClaimStatus @default(DRAFT) // -- Status klaim ini.

  // Entertainment-specific fields
  entertainmentType     EntertainmentType? // -- Jenis jamuan klaim ini.
  entertainmentDate     DateTime? // -- Tanggal jamuan klaim ini.
  entertainmentLocation String?            @db.VarChar(255) // -- Lokasi jamuan klaim ini.
  entertainmentAddress  String?            @db.Text // -- Alamat jamuan klaim ini.
  guestName             String?            @db.VarChar(255) // -- Nama tamu klaim ini.
  guestCompany          String?            @db.VarChar(255) // -- Perusahaan tamu klaim ini.
  guestPosition         String?            @db.VarChar(100) // -- Jabatan tamu klaim ini.
  isGovernmentOfficial  Boolean?           @default(false) // -- Menandakan apakah klaim ini merupakan pejabat pemerintah.

  // Non-entertainment-specific fields
  expenseCategory    NonEntertainmentCategory? // -- Kategori pengeluaran klaim ini.
  expenseDate        DateTime? // -- Tanggal pengeluaran klaim ini.
  expenseDestination String?                   @db.VarChar(255) // -- Tujuan pengeluaran klaim ini.
  customerName       String?                   @db.VarChar(255) // -- Nama pelanggan klaim ini.

  // Common fields
  amount      Decimal @db.Decimal(15, 2) // -- Nominal klaim ini.
  description String  @db.Text // -- Deskripsi klaim ini.
  notes       String? @db.Text // -- Catatan klaim ini.

  // Chart of Accounts
  coaId          String? // -- ID akun COA yang terkait dengan klaim ini.
  chartOfAccount ChartOfAccount? @relation(fields: [coaId], references: [id]) // -- Relasi ke akun COA untuk klaim ini.

  // Payment
  isPaid           Boolean   @default(false) // -- Menandakan apakah klaim ini sudah dibayar.
  paidAt           DateTime? // -- Waktu pembayaran klaim ini.
  paidBy           String?   @db.VarChar(100) // -- Pihak pembayar klaim ini.
  paymentReference String?   @db.VarChar(100) // -- Referensi pembayaran klaim ini.

  // Metadata
  submittedVia String? @db.VarChar(50) // -- Sumber pengajuan klaim ini.

  // Finance officer who processed/paid this claim
  financeId String? // -- ID petugas keuangan yang terkait dengan klaim ini.
  finance   User?   @relation("FinanceClaims", fields: [financeId], references: [id]) // -- Relasi ke pengguna untuk klaim ini.

  deletedAt DateTime? // -- Waktu penghapusan lunak klaim ini.
  createdAt DateTime  @default(now()) // -- Waktu pembuatan klaim ini.
  updatedAt DateTime  @updatedAt // -- Waktu terakhir pembaruan klaim ini.

  // Relations
  attachments         Attachment[] // -- Daftar lampiran yang terkait dengan klaim ini.
  approvals           Approval[] // -- Daftar persetujuan yang terkait dengan klaim ini.
  journalTransactions JournalTransaction[] // -- Daftar transaksi jurnal yang terkait dengan klaim ini.
  journalEntries      JournalEntry[] // -- Daftar entri jurnal yang terkait dengan klaim ini.

  @@unique([claimNumber])
  @@index([travelRequestId])
  @@index([submitterId, status])
  @@index([status, createdAt])
  @@index([claimNumber])
  @@index([claimType])
  @@index([coaId])
  @@index([financeId])
}

model Attachment {
  id       String  @id @default(cuid()) // -- ID unik lampiran ini.
  claimId  String // -- ID klaim yang terkait dengan lampiran ini.
  claim    Claim   @relation(fields: [claimId], references: [id], onDelete: Cascade) // -- Relasi ke klaim untuk lampiran ini.


  filename        String @db.VarChar(255) // -- Nama file lampiran ini.
  originalName    String @db.VarChar(255) // -- Nama file asli lampiran ini.
  mimeType        String @db.VarChar(100) // -- Tipe MIME lampiran ini.
  fileSize        Int // -- Ukuran file lampiran ini.
  storageUrl      String @db.Text // -- URL penyimpanan lampiran ini.
  storageProvider String @db.VarChar(50) // -- Penyedia penyimpanan lampiran ini.

  // OCR/AI extracted data
  ocrExtractedData Json? // -- Data hasil OCR lampiran ini.
  ocrConfidence    Decimal? @db.Decimal(5, 2) // -- Tingkat keyakinan OCR lampiran ini.

  deletedAt DateTime? // -- Waktu penghapusan lunak lampiran ini.
  createdAt DateTime  @default(now()) // -- Waktu pembuatan lampiran ini.
  @@index([claimId])
}

// ============================================================================
// NOTIFICATION SYSTEM
// ============================================================================

model Notification {
  id       String  @id @default(cuid()) // -- ID unik notifikasi ini.
  userId   String // -- ID pengguna yang terkait dengan notifikasi ini.
  user     User    @relation(fields: [userId], references: [id]) // -- Relasi ke pengguna untuk notifikasi ini.


  // Notification content
  title   String              @db.VarChar(255) // -- Judul notifikasi ini.
  message String              @db.Text // -- Pesan notifikasi ini.
  channel NotificationChannel // -- Kanal notifikasi ini.
  status  NotificationStatus  @default(PENDING) // -- Status notifikasi ini.

  // Links
  entityType String? @db.VarChar(50) // -- Tipe entitas notifikasi ini.
  entityId   String? // -- ID entitas yang terkait dengan notifikasi ini.
  actionUrl  String? @db.Text // -- URL aksi notifikasi ini.

  // Delivery
  sentAt       DateTime? // -- Waktu pengiriman notifikasi ini.
  deliveredAt  DateTime? // -- Waktu penerimaan notifikasi ini.
  readAt       DateTime? // -- Waktu pembacaan notifikasi ini.
  failedAt     DateTime? // -- Waktu kegagalan notifikasi ini.
  errorMessage String?   @db.Text // -- Pesan kesalahan notifikasi ini.

  // Metadata
  priority   String  @default("NORMAL") @db.VarChar(20) // -- Prioritas notifikasi ini.
  templateId String? @db.VarChar(100) // -- ID template yang terkait dengan notifikasi ini.

  createdAt DateTime @default(now()) // -- Waktu pembuatan notifikasi ini.
  @@index([userId, status])
  @@index([status, createdAt])
  @@index([channel])
}

// ============================================================================
// AUDIT & COMPLIANCE
// ============================================================================

model AuditLog {
  id       String  @id @default(cuid()) // -- ID unik log audit ini.
  userId   String // -- ID pengguna yang terkait dengan log audit ini.
  user     User    @relation(fields: [userId], references: [id]) // -- Relasi ke pengguna untuk log audit ini.


  // Action details
  action     AuditAction // -- Aksi log audit ini.
  entityType String      @db.VarChar(50) // -- Tipe entitas log audit ini.
  entityId   String // -- ID entitas yang terkait dengan log audit ini.

  // Chart of Accounts relation (optional)
  chartOfAccountId String? // -- ID akun COA yang terkait dengan log audit ini.
  chartOfAccount   ChartOfAccount? @relation("COAAuditLogs", fields: [chartOfAccountId], references: [id]) // -- Relasi ke akun COA untuk log audit ini.

  // Changes
  changes  Json? // -- Perubahan data log audit ini.
  metadata Json? // -- Metadata log audit ini.

  // Request info
  ipAddress String? @db.VarChar(45) // -- Alamat IP log audit ini.
  userAgent String? @db.Text // -- Informasi user agent log audit ini.

  createdAt DateTime @default(now()) // -- Waktu pembuatan log audit ini.
  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@index([chartOfAccountId])
}

// ============================================================================
// ACCOUNTING — BALANCE ACCOUNTS & JOURNAL TRANSACTIONS
// ============================================================================

model BalanceAccount {
  id       String  @id @default(cuid()) // -- ID unik akun saldo ini.
  code     String  @db.VarChar(30) // -- Kode akun saldo ini.
  name     String  @db.VarChar(150) // -- Nama akun saldo ini.


  // Current running balance (positive = debit-normal, or as defined by usage)
  balance Decimal @default(0) @db.Decimal(19, 4) // -- Saldo akun saldo ini.

  defaultChartOfAccountId String? // -- ID akun COA bawaan yang terkait dengan akun saldo ini.
  defaultChartOfAccount   ChartOfAccount? @relation("BalanceAccountDefaultCOA", fields: [defaultChartOfAccountId], references: [id]) // -- Relasi ke akun COA untuk akun saldo ini.

  isActive    Boolean @default(true) // -- Menandakan apakah akun saldo ini aktif.
  description String? @db.Text // -- Deskripsi akun saldo ini.

  deletedAt DateTime? // -- Waktu penghapusan lunak akun saldo ini.
  createdAt DateTime  @default(now()) // -- Waktu pembuatan akun saldo ini.
  updatedAt DateTime  @updatedAt // -- Waktu terakhir pembaruan akun saldo ini.

  // Reverse relation
  journalTransactions JournalTransaction[] // -- Daftar transaksi jurnal yang terkait dengan akun saldo ini.
  journalEntryLines   JournalEntryLine[] // -- Daftar baris entri jurnal yang terkait dengan akun saldo ini.

  @@unique([code])
  @@index([code])
  @@index([isActive])
  @@index([defaultChartOfAccountId])
}

model JournalTransaction {
  id                String  @id @default(cuid()) // -- ID unik transaksi jurnal ini.
  transactionNumber String  @db.VarChar(50) // -- Nomor transaksi jurnal ini.


  // Date of the accounting entry (may differ from createdAt)
  transactionDate DateTime @db.Date // -- Tanggal transaksi jurnal ini.

  description String  @db.Text // -- Deskripsi transaksi jurnal ini.
  amount      Decimal @db.Decimal(15, 2) // -- Nominal transaksi jurnal ini.

  // DEBIT increases the account balance; CREDIT decreases it (or vice-versa
  // depending on account type — the application layer enforces the rule).
  entryType JournalEntryType // -- Jenis entri transaksi jurnal ini.

  // ── Source document links (at most one set) ──────────────────────────────
  bailoutId String? // -- ID dana talangan yang terkait dengan transaksi jurnal ini.
  bailout   Bailout? @relation(fields: [bailoutId], references: [id]) // -- Relasi ke dana talangan untuk transaksi jurnal ini.

  claimId String? // -- ID klaim yang terkait dengan transaksi jurnal ini.
  claim   Claim?  @relation(fields: [claimId], references: [id]) // -- Relasi ke klaim untuk transaksi jurnal ini.

  // ── Accounting links (both required) ─────────────────────────────────────
  chartOfAccountId String // -- ID akun COA yang terkait dengan transaksi jurnal ini.
  chartOfAccount   ChartOfAccount @relation(fields: [chartOfAccountId], references: [id]) // -- Relasi ke akun COA untuk transaksi jurnal ini.

  balanceAccountId String // -- ID akun saldo yang terkait dengan transaksi jurnal ini.
  balanceAccount   BalanceAccount @relation(fields: [balanceAccountId], references: [id]) // -- Relasi ke akun saldo untuk transaksi jurnal ini.

  // Optional reference / notes
  referenceNumber String? @db.VarChar(100) // -- Nomor referensi transaksi jurnal ini.
  notes           String? @db.Text // -- Catatan transaksi jurnal ini.

  // Soft-delete
  deletedAt DateTime? // -- Waktu penghapusan lunak transaksi jurnal ini.
  createdAt DateTime  @default(now()) // -- Waktu pembuatan transaksi jurnal ini.
  updatedAt DateTime  @updatedAt // -- Waktu terakhir pembaruan transaksi jurnal ini.

  @@unique([transactionNumber])
  @@index([transactionNumber])
  @@index([transactionDate])
  @@index([chartOfAccountId])
  @@index([balanceAccountId])
  @@index([bailoutId])
  @@index([claimId])
  @@index([entryType, transactionDate])
}

model JournalEntry {
  id            String  @id @default(cuid()) // -- ID unik entri jurnal ini.
  journalNumber String  @db.VarChar(50) // -- Nomor jurnal ini.


  transactionDate DateTime           @db.Date // -- Tanggal transaksi entri jurnal ini.
  description     String             @db.Text // -- Deskripsi entri jurnal ini.
  sourceType      JournalSourceType? // -- Tipe sumber entri jurnal ini.
  sourceId        String? // -- ID sumber yang terkait dengan entri jurnal ini.
  status          JournalStatus      @default(DRAFT) // -- Status entri jurnal ini.

  bailoutId String? // -- ID dana talangan yang terkait dengan entri jurnal ini.
  bailout   Bailout? @relation(fields: [bailoutId], references: [id]) // -- Relasi ke dana talangan untuk entri jurnal ini.

  claimId String? // -- ID klaim yang terkait dengan entri jurnal ini.
  claim   Claim?  @relation(fields: [claimId], references: [id]) // -- Relasi ke klaim untuk entri jurnal ini.

  referenceNumber String? @db.VarChar(100) // -- Nomor referensi entri jurnal ini.
  notes           String? @db.Text // -- Catatan entri jurnal ini.

  createdById String // -- ID pengguna pembuat yang terkait dengan entri jurnal ini.
  createdBy   User   @relation("JournalEntryCreatedBy", fields: [createdById], references: [id]) // -- Relasi ke pengguna untuk entri jurnal ini.

  postedById String? // -- ID pengguna yang melakukan posting untuk entri jurnal ini.
  postedBy   User?     @relation("JournalEntryPostedBy", fields: [postedById], references: [id]) // -- Relasi ke pengguna untuk entri jurnal ini.
  postedAt   DateTime? // -- Waktu posting entri jurnal ini.

  deletedAt DateTime? // -- Waktu penghapusan lunak entri jurnal ini.
  createdAt DateTime  @default(now()) // -- Waktu pembuatan entri jurnal ini.
  updatedAt DateTime  @updatedAt // -- Waktu terakhir pembaruan entri jurnal ini.

  lines JournalEntryLine[] // -- Daftar baris entri jurnal yang terkait dengan entri jurnal ini.

  @@unique([journalNumber])
  @@index([journalNumber])
  @@index([transactionDate])
  @@index([sourceType, sourceId])
  @@index([status, transactionDate])
  @@index([bailoutId])
  @@index([claimId])
  @@index([createdById])
  @@index([postedById])
}

model JournalEntryLine {
  id String @id @default(cuid()) // -- ID unik baris entri jurnal ini.

  journalEntryId String // -- ID entri jurnal yang terkait dengan baris entri jurnal ini.
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade) // -- Relasi ke entri jurnal untuk baris entri jurnal ini.

  chartOfAccountId String // -- ID akun COA yang terkait dengan baris entri jurnal ini.
  chartOfAccount   ChartOfAccount @relation(fields: [chartOfAccountId], references: [id]) // -- Relasi ke akun COA untuk baris entri jurnal ini.

  balanceAccountId String? // -- ID akun saldo yang terkait dengan baris entri jurnal ini.
  balanceAccount   BalanceAccount? @relation(fields: [balanceAccountId], references: [id]) // -- Relasi ke akun saldo untuk baris entri jurnal ini.

  description  String? @db.Text // -- Deskripsi baris entri jurnal ini.
  debitAmount  Decimal @default(0) @db.Decimal(15, 2) // -- Nominal debit baris entri jurnal ini.
  creditAmount Decimal @default(0) @db.Decimal(15, 2) // -- Nominal kredit baris entri jurnal ini.
  lineNumber   Int     @default(1) // -- Nomor baris entri jurnal ini.

  createdAt DateTime @default(now()) // -- Waktu pembuatan baris entri jurnal ini.
  updatedAt DateTime @updatedAt // -- Waktu terakhir pembaruan baris entri jurnal ini.

  @@index([journalEntryId])
  @@index([chartOfAccountId])
  @@index([balanceAccountId])
  @@index([lineNumber])
}

