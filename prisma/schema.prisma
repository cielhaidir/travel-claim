// Travel and Claim Management System - Prisma Schema
// Database: PostgreSQL
// Generated Prisma Client: ../generated/prisma

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

