model CrmActivity {
  id          String          @id @default(cuid()) // -- ID unik aktivitas CRM ini.
  customerId  String? // -- ID pelanggan yang terkait dengan aktivitas CRM ini.
  leadId      String? // -- ID prospek yang terkait dengan aktivitas CRM ini.
  dealId      String? // -- ID deal yang terkait dengan aktivitas CRM ini.
  conversationId String? // -- ID percakapan yang terkait dengan aktivitas CRM ini.
  messageId   String? // -- ID pesan yang terkait dengan aktivitas CRM ini.
  title       String          @db.VarChar(200) // -- Judul aktivitas CRM ini.
  description String?         @db.Text // -- Deskripsi aktivitas CRM ini.
  type        CrmActivityType @default(FOLLOW_UP) // -- Tipe aktivitas CRM ini.
  ownerName   String          @db.VarChar(150) // -- Nama pemilik aktivitas CRM ini.
  scheduledAt DateTime // -- Waktu jadwal aktivitas CRM ini.
  completedAt DateTime? // -- Waktu penyelesaian aktivitas CRM ini.
  deletedAt   DateTime? // -- Waktu penghapusan lunak aktivitas CRM ini.
  createdAt   DateTime        @default(now()) // -- Waktu pembuatan aktivitas CRM ini.
  updatedAt   DateTime        @updatedAt // -- Waktu terakhir pembaruan aktivitas CRM ini.

  customer     CrmCustomer?      @relation(fields: [customerId], references: [id], onDelete: SetNull) // -- Relasi ke pelanggan CRM untuk aktivitas CRM ini.
  lead         CrmLead?          @relation(fields: [leadId], references: [id], onDelete: SetNull) // -- Relasi ke prospek CRM untuk aktivitas CRM ini.
  deal         CrmDeal?          @relation(fields: [dealId], references: [id], onDelete: SetNull) // -- Relasi ke deal CRM untuk aktivitas CRM ini.
  conversation CrmConversation?  @relation(fields: [conversationId], references: [id], onDelete: SetNull) // -- Relasi ke percakapan CRM untuk aktivitas CRM ini.
  message      CrmMessage?       @relation(fields: [messageId], references: [id], onDelete: SetNull) // -- Relasi ke pesan CRM untuk aktivitas CRM ini.
  @@index([customerId])
  @@index([leadId])
  @@index([dealId])
  @@index([conversationId])
  @@index([messageId])
  @@index([deletedAt])
}

model CrmConversation {
  id                 String                @id @default(cuid()) // -- ID unik percakapan CRM ini.
  customerId         String? // -- ID customer yang terkait dengan percakapan CRM ini.
  leadId             String? // -- ID lead yang terkait dengan percakapan CRM ini.
  dealId             String? // -- ID deal yang terkait dengan percakapan CRM ini.
  subject            String?               @db.VarChar(200) // -- Subjek percakapan CRM ini.
  ownerName          String                @db.VarChar(150) // -- Nama pemilik percakapan CRM ini.
  status             CrmConversationStatus @default(OPEN) // -- Status percakapan CRM ini.
  lastMessageAt      DateTime? // -- Waktu pesan terakhir percakapan CRM ini.
  lastMessagePreview String?               @db.VarChar(255) // -- Ringkasan pesan terakhir percakapan CRM ini.
  deletedAt          DateTime? // -- Waktu penghapusan lunak percakapan CRM ini.
  createdAt          DateTime              @default(now()) // -- Waktu pembuatan percakapan CRM ini.
  updatedAt          DateTime              @updatedAt // -- Waktu terakhir pembaruan percakapan CRM ini.

  customer   CrmCustomer?   @relation(fields: [customerId], references: [id], onDelete: SetNull) // -- Relasi ke customer CRM untuk percakapan CRM ini.
  lead       CrmLead?       @relation(fields: [leadId], references: [id], onDelete: SetNull) // -- Relasi ke lead CRM untuk percakapan CRM ini.
  deal       CrmDeal?       @relation(fields: [dealId], references: [id], onDelete: SetNull) // -- Relasi ke deal CRM untuk percakapan CRM ini.
  messages   CrmMessage[] // -- Daftar pesan yang terkait dengan percakapan CRM ini.
  activities CrmActivity[] // -- Daftar aktivitas yang terkait dengan percakapan CRM ini.
  @@index([customerId])
  @@index([leadId])
  @@index([dealId])
  @@index([deletedAt])
}

model CrmMessage {
  id             String           @id @default(cuid()) // -- ID unik pesan CRM ini.
  conversationId String // -- ID percakapan yang terkait dengan pesan CRM ini.
  status         CrmMessageStatus @default(SENT) // -- Status pesan CRM ini.
  senderName     String           @db.VarChar(150) // -- Nama pengirim pesan CRM ini.
  body           String           @db.Text // -- Isi pesan CRM ini.
  sentAt         DateTime         @default(now()) // -- Waktu pengiriman pesan CRM ini.
  deletedAt      DateTime? // -- Waktu penghapusan lunak pesan CRM ini.
  createdAt      DateTime         @default(now()) // -- Waktu pembuatan pesan CRM ini.
  updatedAt      DateTime         @updatedAt // -- Waktu terakhir pembaruan pesan CRM ini.

  conversation CrmConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade) // -- Relasi ke percakapan CRM untuk pesan CRM ini.
  activities   CrmActivity[] // -- Daftar aktivitas yang terkait dengan pesan CRM ini.
  @@index([conversationId])
  @@index([deletedAt])
}

