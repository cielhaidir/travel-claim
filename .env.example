# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Next Auth
# You can generate a new secret on the command line with:
# npx auth secret
# https://next-auth.js.org/configuration/options#secret
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Microsoft Entra ID (Azure AD) Provider
# Register app at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Required API permissions: openid, profile, email, offline_access, User.Read
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# Prisma
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
DATABASE_URL="postgresql://postgres:password@localhost:5432/travel-claim"

# Redis (optional — only required for MCP legacy SSE transport at /api/mcp/sse)
# The modern Streamable HTTP transport at /api/mcp/mcp works without Redis.
# Local: redis://localhost:6379
# Upstash: rediss://<user>:<password>@<host>:<port>
REDIS_URL=""

# MCP API Token (optional — allows header-based auth for MCP tools, e.g. Roo/Claude Desktop)
# When set, requests with "Authorization: Bearer <token>" header will be authenticated
# as the user whose email matches MCP_API_TOKEN_USER_EMAIL below.
# Generate a random token: openssl rand -hex 32
MCP_API_TOKEN=""
MCP_API_TOKEN_USER_EMAIL=""

# WhatsApp notification gateway (WA-JS / Baileys compatible)
# Base URL of your WhatsApp API server, e.g. https://wa.example.com
WHATSAPP_BASE_URL=""
# Device/session ID passed as header to the API
WHATSAPP_DEVICE_ID=""
# Basic auth in "username:password" format — will be base64-encoded at runtime
WHATSAPP_BASIC_AUTH=""

# Cloudflare R2 Storage (S3-compatible)
# Found in Cloudflare Dashboard → R2 → Manage API Tokens
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
# The bucket name you created in R2
R2_BUCKET_NAME=""
# Public URL for the bucket (enable public access in R2 dashboard, or use a custom domain)
# e.g. https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
R2_PUBLIC_URL=""
